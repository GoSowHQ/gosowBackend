generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  BACKER
  CREATOR
  ADMIN
}

enum AuthProvider {
  LOCAL
  GOOGLE
  GITHUB
}

enum ProjectStatus {
  DRAFT
  PENDING
  ACTIVE
  FUNDED
  EXPIRED
  CANCELLED
}

enum ProjectCategory {
  AI_ML
  SAAS
  DEVELOPER_TOOLS
  OPEN_SOURCE
  HARDWARE
  WEB3
  MOBILE_APPS
  HACKATHONS
  TECH_EVENTS
  OTHER
}

enum FundingStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
}

enum PaymentProvider {
  STRIPE
  INTERSWITCH
}

enum PaymentChannel {
  CARD
  BANK_TRANSFER
  VIRTUAL_ACCOUNT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  SETTLED
  FAILED
  REFUNDED
}

enum VirtualAccountStatus {
  PENDING
  ACTIVE
  DISABLED
  FAILED
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
  IGNORED
}

enum LedgerEntryType {
  PAYMENT_GROSS
  PROCESSOR_FEE
  PLATFORM_FEE
  PAYOUT_DEBIT
  PAYOUT_REVERSAL
  REFUND_DEBIT
  MANUAL_ADJUSTMENT
}

enum BankAccountStatus {
  PENDING
  VERIFIED
  DISABLED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  SUCCESSFUL
  FAILED
  CANCELLED
}

enum EventType {
  HACKATHON
  WORKSHOP
  MEETUP
  LAUNCH_PARTY
  DEMO_DAY
  WEBINAR
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

model User {
  id            String       @id @default(uuid())
  email         String       @unique
  passwordHash  String?      @map("password_hash")
  name          String
  avatarUrl     String?      @map("avatar_url")
  bio           String?
  role          UserRole     @default(BACKER)
  provider      AuthProvider @default(LOCAL)
  providerId    String?      @map("provider_id")
  emailVerified Boolean      @default(false) @map("email_verified")
  isActive      Boolean      @default(true) @map("is_active")
  refreshToken  String?      @map("refresh_token")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  projects           Project[]
  fundings           Funding[]
  comments           Comment[]
  bookmarks          Bookmark[]
  eventRegistrations EventRegistration[]
  projectUpdates     ProjectUpdate[]
  wallet             Wallet?
  bankAccounts       CreatorBankAccount[]
  payoutRequests     PayoutRequest[]

  @@index([email])
  @@index([provider, providerId])
  @@map("users")
}

model Project {
  id               String          @id @default(uuid())
  title            String
  slug             String          @unique
  description      String
  shortDescription String?         @map("short_description")
  imageUrl         String?         @map("image_url")
  category         ProjectCategory @default(OTHER)
  status           ProjectStatus   @default(DRAFT)
  goalAmount       Float           @map("goal_amount")
  currentAmount    Float           @default(0) @map("current_amount")
  backerCount      Int             @default(0) @map("backer_count")
  startDate        DateTime?       @map("start_date")
  endDate          DateTime?       @map("end_date")
  featured         Boolean         @default(false)
  creatorId        String          @map("creator_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  creator  User            @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  rewards  Reward[]
  fundings Funding[]
  payments Payment[]
  comments Comment[]
  updates  ProjectUpdate[]
  bookmarks Bookmark[]
  virtualAccount CampaignVirtualAccount?
  ledgerEntries LedgerEntry[]
  payoutRequests PayoutRequest[]

  @@index([slug])
  @@index([creatorId])
  @@index([status])
  @@index([category])
  @@index([featured])
  @@map("projects")
}

model Reward {
  id          String   @id @default(uuid())
  title       String
  description String
  amount      Float
  quantity    Int?
  claimed     Int      @default(0)
  imageUrl    String?  @map("image_url")
  deliveryDate DateTime? @map("delivery_date")
  projectId   String   @map("project_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fundings Funding[]

  @@index([projectId])
  @@map("rewards")
}

model Wallet {
  id            String   @id @default(uuid())
  accountNumber String   @unique @map("account_number")
  balance       Float    @default(0)
  userId        String   @unique @map("user_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model CampaignVirtualAccount {
  id                 String               @id @default(uuid())
  projectId          String               @unique @map("project_id")
  provider           PaymentProvider      @default(INTERSWITCH)
  status             VirtualAccountStatus @default(PENDING)
  accountNumber      String?              @unique @map("account_number")
  accountName        String?              @map("account_name")
  bankCode           String?              @map("bank_code")
  bankName           String?              @map("bank_name")
  payableCode        String?              @map("payable_code")
  externalReference  String?              @unique @map("external_reference")
  metadata           Json?
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([status])
  @@map("campaign_virtual_accounts")
}

model Funding {
  id              String        @id @default(uuid())
  amount          Float
  status          FundingStatus @default(PENDING)
  isAnonymous     Boolean       @default(false) @map("is_anonymous")
  stripePaymentId String?       @unique @map("stripe_payment_id")
  userId          String        @map("user_id")
  projectId       String        @map("project_id")
  rewardId        String?       @map("reward_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reward  Reward?  @relation(fields: [rewardId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@map("fundings")
}

model Payment {
  id                    String           @id @default(uuid())
  projectId             String           @map("project_id")
  virtualAccountId      String?          @map("virtual_account_id")
  provider              PaymentProvider
  channel               PaymentChannel
  status                PaymentStatus    @default(PENDING)
  amountMinor           Int              @map("amount_minor")
  processorFeeMinor     Int              @default(0) @map("processor_fee_minor")
  platformFeeMinor      Int              @default(0) @map("platform_fee_minor")
  netAmountMinor        Int              @default(0) @map("net_amount_minor")
  currency              String           @default("NGN")
  providerPaymentId     String?          @unique @map("provider_payment_id")
  providerReference     String?          @unique @map("provider_reference")
  merchantReference     String?          @unique @map("merchant_reference")
  payerName             String?          @map("payer_name")
  payerAccountNumber    String?          @map("payer_account_number")
  paidAt                DateTime?        @map("paid_at")
  settledAt             DateTime?        @map("settled_at")
  metadata              Json?
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  project        Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  virtualAccount CampaignVirtualAccount? @relation(fields: [virtualAccountId], references: [id], onDelete: SetNull)
  ledgerEntries  LedgerEntry[]

  @@index([projectId])
  @@index([virtualAccountId])
  @@index([status])
  @@index([provider])
  @@map("payments")
}

model WebhookEvent {
  id              String             @id @default(uuid())
  provider        PaymentProvider
  eventType       String             @map("event_type")
  externalEventId String             @unique @map("external_event_id")
  status          WebhookEventStatus @default(RECEIVED)
  payload         Json
  errorMessage    String?            @map("error_message")
  processedAt     DateTime?          @map("processed_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  @@index([provider])
  @@index([status])
  @@map("webhook_events")
}

model LedgerEntry {
  id              String          @id @default(uuid())
  projectId       String          @map("project_id")
  paymentId       String?         @map("payment_id")
  payoutRequestId String?         @map("payout_request_id")
  type            LedgerEntryType
  amountMinor     Int             @map("amount_minor")
  currency        String          @default("NGN")
  description     String?
  metadata        Json?
  createdAt       DateTime        @default(now()) @map("created_at")

  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  payment       Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  payoutRequest PayoutRequest? @relation(fields: [payoutRequestId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([paymentId])
  @@index([payoutRequestId])
  @@index([type])
  @@map("ledger_entries")
}

model CreatorBankAccount {
  id                String            @id @default(uuid())
  userId            String            @map("user_id")
  bankCode          String            @map("bank_code")
  bankName          String            @map("bank_name")
  accountNumber     String            @map("account_number")
  accountName       String            @map("account_name")
  status            BankAccountStatus @default(PENDING)
  isDefault         Boolean           @default(false) @map("is_default")
  recipientCode     String?           @map("recipient_code")
  externalReference String?           @unique @map("external_reference")
  metadata          Json?
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  payoutRequests PayoutRequest[]

  @@index([userId])
  @@index([status])
  @@unique([userId, accountNumber, bankCode])
  @@map("creator_bank_accounts")
}

model PayoutRequest {
  id                String       @id @default(uuid())
  userId            String       @map("user_id")
  projectId         String       @map("project_id")
  bankAccountId     String       @map("bank_account_id")
  amountMinor       Int          @map("amount_minor")
  feeMinor          Int          @default(0) @map("fee_minor")
  netAmountMinor    Int          @default(0) @map("net_amount_minor")
  currency          String       @default("NGN")
  status            PayoutStatus @default(PENDING)
  providerReference String?      @unique @map("provider_reference")
  providerPayoutId  String?      @unique @map("provider_payout_id")
  failureReason     String?      @map("failure_reason")
  processedAt       DateTime?    @map("processed_at")
  metadata          Json?
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bankAccount  CreatorBankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Restrict)
  ledgerEntries LedgerEntry[]

  @@index([userId])
  @@index([projectId])
  @@index([bankAccountId])
  @@index([status])
  @@map("payout_requests")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  userId    String   @map("user_id")
  projectId String   @map("project_id")
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([projectId])
  @@index([userId])
  @@index([parentId])
  @@map("comments")
}

model ProjectUpdate {
  id        String   @id @default(uuid())
  title     String
  content   String
  projectId String   @map("project_id")
  authorId  String   @map("author_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_updates")
}

model Event {
  id          String      @id @default(uuid())
  title       String
  slug        String      @unique
  description String
  type        EventType
  status      EventStatus @default(UPCOMING)
  imageUrl    String?     @map("image_url")
  location    String?
  isVirtual   Boolean     @default(false) @map("is_virtual")
  meetingUrl  String?     @map("meeting_url")
  startDate   DateTime    @map("start_date")
  endDate     DateTime    @map("end_date")
  maxAttendees Int?       @map("max_attendees")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  registrations EventRegistration[]

  @@index([slug])
  @@index([status])
  @@index([type])
  @@map("events")
}

model EventRegistration {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  eventId   String   @map("event_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId])
  @@map("event_registrations")
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  projectId String   @map("project_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
  @@map("bookmarks")
}
